# Database (matches compose.yml)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=issueflow
DB_PASSWORD=issueflow
DB_NAME=issueflow

# Auth
JWT_SECRET=change-me-in-prod
JWT_EXPIRES_IN=3600

# App
PORT=3000

# File uploads (local filesystem — swap for S3-style in production)
UPLOADS_DIR=./uploads

# Escalation cron schedule (standard 5-field cron: minute hour dom month dow).
# IMPORTANT: this is read from the OS environment at process start, not from
# this .env file — the @Cron decorator is evaluated before ConfigModule loads
# dotenv. Export it in your shell if you need a non-default schedule.
# Default when the variable is unset: every 15 minutes.
ESCALATION_CRON=*/15 * * * *
